@model IManager.Web.Presentation.ViewModels.Companies.CompanyViewModel

@{
    ViewData["Title"] = "Detalhes";
}

<h1>Detalhes</h1>

<div>
    <h4>Company</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            CNPJ:
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DocumentNumber)
        </dd>
        <dt class = "col-sm-2">
            Razão Social:
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.LegalName)
        </dd>
        <dt class = "col-sm-2">
            Nome Fantasia:
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TradeName)
        </dd>
        <dt class = "col-sm-2">
            Data de Fundação:
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FoundedAt)
        </dd>
        <dt class = "col-sm-2">
            Data de Criação:
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CreatedAt)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Editar</a> |
    <a asp-action="Index">Voltar</a>
</div>
