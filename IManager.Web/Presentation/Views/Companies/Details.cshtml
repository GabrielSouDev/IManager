@model DetailsCompanyViewModel

@{
    ViewData["Title"] = "Detalhes de Empresa";
}

<h1>Detalhes</h1>

<div>
    <h4>Empresa</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">CNPJ:</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.DocumentNumber)</dd>

        <dt class="col-sm-2">Razão Social:</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.LegalName)</dd>

        <dt class="col-sm-2">Nome Fantasia:</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.TradeName)</dd>

        <dt class="col-sm-2">Data de Fundação:</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.FoundedAt)</dd>

        <dt class="col-sm-2">Data de Criação:</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.CreatedAt)</dd>

        <dt class="col-sm-2">Ativa:</dt>
        <dd class="col-sm-10">
            @(Model.IsActive ? "Sim" : "Não")
        </dd>
    </dl>
</div>

<div>
    <h4>Informações Adicionais</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">Quantidade de Funcionários:</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Info.EmployeeCount)</dd>

        <dt class="col-sm-2">Quantidade de Departamentos:</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Info.DepartmentCount)</dd>

        <dt class="col-sm-2">Salário Médio:</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Info.AverageSalary)</dd>

        <dt class="col-sm-2">Custo Anual da Folha:</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Info.AnnualPayrollCost)</dd>

        <dt class="col-sm-2">Último Usuário Registrado:</dt>
        <dd class="col-sm-10">@Model.Info.LastCreatedUser - @Model.Info.LastCreatedDate</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Editar</a> |
    <a asp-action="Index">Voltar</a>
</div>
