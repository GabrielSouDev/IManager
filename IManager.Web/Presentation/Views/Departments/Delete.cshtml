@model DepartmentViewModel

@{
    ViewData["Title"] = "Atualizar Setor";
}

<h1>@(Model.IsActive ? "Desativar" : "Ativar")</h1>

<h3>Você tem certeza que deseja @(Model.IsActive ? "Desativar" : "Ativar") este Setor?</h3>
<div>
    <h4>Department</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedAt)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CreatedAt)
        </dd>
        @if(User.IsInRole(Role.Staff))
        {
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Company.TradeName)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Company.TradeName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Company.LegalName)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Company.LegalName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Company.DocumentNumber)
            </dt>
            <dd class="col-sm-10">
                @MaskHelper.MaskCnpj(Model.Company.DocumentNumber)
            </dd>
        }
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="@(Model.IsActive ? "Desativar" : "Ativar")" class="btn btn-danger" /> |
        <a asp-action="Index">Voltar</a>
    </form>
</div>
