@using IManager.Web.Presentation.ViewModels.Departments
@model IManager.Web.Presentation.ViewModels.Account.EditAccountViewModel

@{
    ViewData["Title"] = "Edit";

    var departments = ViewBag.Departments as IEnumerable<DepartmentHierarchyViewModel>;
}

<h1>Editar Usuario</h1>

<h4>UserProfile</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group">
                    <input type="hidden" asp-for="CompanyId" />
                    <label>Departamento</label>

                    <select id="departmentSelect" asp-for="DepartmentId" class="form-control">

                        @if (departments != null)
                        {
                            @foreach (var department in departments)
                            {
                                <option value="@department.Id"  
                                        selected="@(department.Id == Model.DepartmentId ? "selected" : null)">
                                    @department.Name
                                </option>
                            }
                        }

                    </select>

                </div>

                <div class="form-group">
                    <label>Cargo</label>

                    <select id="jobTitleSelect" asp-for="JobTitleId" class="form-control">
                    </select>

                </div>

            <div class="mb-3">
                <label class="form-label fw-500 small">
                    Salário Base: <span class="text-danger">*</span>
                </label>
                <input type="text"
                       id="salaryDisplay"
                       class="form-control"
                       placeholder="R$ 0,00"
                       autocomplete="off" />
                <input type="hidden" asp-for="BaseSalary" id="salaryHidden" />
                <span asp-validation-for="BaseSalary" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="FullName" class="control-label">Nime Completo: <span class="text-danger">*</span></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DocumentNumber" class="form-label fw-500 small">CPF: <span class="text-danger">*</span></label>
                <input asp-for="DocumentNumber" id="cpf" class="form-control" inputmode="numeric" />
                <span asp-validation-for="DocumentNumber" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PhoneNumber" class="form-label fw-500 small">Telefone <span class="text-muted">(opcional)</span></label>
                <input asp-for="PhoneNumber" id="phone" class="form-control" placeholder="(11) 99999-9999" />
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="control-label">Email: <span class="text-danger">*</span></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BirthDate" class="form-label fw-500 small">Data de Nascimento: <span class="text-danger">*</span></label>
                <input asp-for="BirthDate" class="form-control" type="date" />
                <span asp-validation-for="BirthDate" class="text-danger small"></span>
            </div>

            <div class="mb-4">

                <label class="form-label fw-500 small">Perfil de Acesso <span class="text-danger">*</span></label>

                <div>
                    @{
                        var rolesAllowed = User.IsInRole(Role.Staff) ? Role.All : Role.AdminAllowed;
                    }

                    @foreach (var role in rolesAllowed)
                    {
                        <div class="form-check form-check-inline">

                            <input class="form-check-input"
                                   type="radio"
                                   asp-for="Role"
                                   value="@role"
                                   id="role_@role" />

                            <label class="form-check-label small" for="role_@role">@role</label>

                        </div>
                    }
                </div>

                <span asp-validation-for="Role" class="text-danger small"></span>

            </div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <input type="submit" value="Salvar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        /* ============================
         * DADOS (Razor -> JS)
         * ============================ */
        const departments = @Html.Raw(
                    System.Text.Json.JsonSerializer.Serialize(
                            departments,
                            new System.Text.Json.JsonSerializerOptions
                            {
                                    PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
                            })
            );

        const selectedJobTitleId = "@Model.JobTitleId";

        const departmentSelect = document.getElementById("departmentSelect");
        const jobTitleSelect   = document.getElementById("jobTitleSelect");

        const cpfInput   = document.getElementById("cpf");
        const phoneInput = document.getElementById("phone");

        const salaryDisplay = document.getElementById("salaryDisplay");
        const salaryHidden  = document.getElementById("salaryHidden");

        const maskCPF = (value) => {
            value = value.replace(/\D/g, "").slice(0, 11);

            if (value.length <= 3) return value;
            if (value.length <= 6) return value.replace(/(\d{3})(\d+)/, "$1.$2");
            if (value.length <= 9) return value.replace(/(\d{3})(\d{3})(\d+)/, "$1.$2.$3");

            return value.replace(
                /(\d{3})(\d{3})(\d{3})(\d{0,2})/,
                "$1.$2.$3-$4"
            );
        };

        const maskPhone = (value) => {
            value = value.replace(/\D/g, "").slice(0, 11);

            if (value.length <= 2) return value;
            if (value.length <= 6) return value.replace(/(\d{2})(\d+)/, "($1) $2");
            if (value.length <= 10) return value.replace(/(\d{2})(\d{4})(\d+)/, "($1) $2-$3");

            return value.replace(/(\d{2})(\d{5})(\d{4})/, "($1) $2-$3");
        };

        const formatMoney = (raw) => {
            raw = raw.replace(/\D/g, "");
            if (!raw) return "";

            const value = (parseInt(raw, 10) / 100).toFixed(2);
            return value.replace(".", ",");
        };

        const loadJobTitles = (departmentId) => {
            jobTitleSelect.innerHTML = `<option value="">Selecione</option>`;

            if (!departmentId) return;

            const department = departments.find(d => d.id === departmentId);
            if (!department) return;

            department.jobTitles.forEach(job => {
                const option = new Option(job.name, job.id);
                option.selected = job.id === selectedJobTitleId;
                jobTitleSelect.add(option);
            });
        };

        document.addEventListener("DOMContentLoaded", () => {

            /* 🔹 Inicializa JobTitles */
            if (departmentSelect.value) {
                loadJobTitles(departmentSelect.value);
            }

            departmentSelect.addEventListener("change", e => {
                loadJobTitles(e.target.value);
            });

            /* 🔹 CPF */
            if (cpfInput?.value) {
                cpfInput.value = maskCPF(cpfInput.value);
            }

            cpfInput?.addEventListener("input", e => {
                e.target.value = maskCPF(e.target.value);
            });

            /* 🔹 Telefone */
            if (phoneInput?.value) {
                phoneInput.value = maskPhone(phoneInput.value);
            }

            phoneInput?.addEventListener("input", e => {
                e.target.value = maskPhone(e.target.value);
            });

            /* 🔹 Salário */
            if (salaryHidden.value) {
                salaryDisplay.value = "R$ " + formatMoney(salaryHidden.value);
            }

            salaryDisplay.addEventListener("input", e => {
                const formatted = formatMoney(e.target.value);
                salaryHidden.value = formatted;
                e.target.value = formatted ? `R$ ${formatted}` : "";
            });
        });
    </script>
}