@using IManager.Web.Shared.Helpers
@model PagedResult<AccountViewModel>

@{
    ViewData["Title"] = "Usuarios";
}

<form method="get" class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <a class="btn btn-sm btn-table" href="/Account/Register">
            Registrar Usuário
        </a>
    </div>

    <div class="input-group w-25">
        <input type="text"
               name="search"
               value="@Model.Search"
               class="form-control"
               placeholder="Pesquisar" />

        <button class="btn btn-sm btn-outline-secondary" type="submit">
            🔍
        </button>
    </div>
</form>

<table id="table" class="table table-hover">
    <thead class="table-light">
        <tr>
            <th>Nome Completo</th>
            <th>CPF</th>
            <th>Dt. Nasc.</th>

            @if (User.IsInRole(Role.Staff))
            {
                <th>Empresa</th>
                <th>CNPJ</th>
            }
            else
            {
                <th>Salario Base</th>
            }

            <th>Setor</th>
            <th>Cargo</th>
            <th>Perfil de Acesso</th>
            <th class="text-center">Ativo</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr data-id="@item.Id">
                <td class="truncate">@item.FullName</td>
                <td>@(MaskHelper.MaskCpf(item.DocumentNumber))</td>
                <td>@item.BirthDate.ToString("dd/MM/yyyy")</td>

                @if (User.IsInRole(Role.Staff))
                {
                    <td>@item.JobTitle.Department.Company.TradeName</td>
                    <td>@(MaskHelper.MaskCnpj(item.JobTitle.Department.Company.DocumentNumber))</td>
                }
                else
                {
                    <td>@(MaskHelper.MaskCurrency(item.BaseSalary))</td>
                }

                <td>@item.JobTitle.Department.Name</td>
                <td>@item.JobTitle.Name</td>
                <td>@item.Role</td>

                <td class="text-center">@(item.IsActive ? "✅" : "❌")</td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-between align-items-center mt-3 mb-3">
    <div class="btn-group gap-1" role="group">
        <button id="btn-edit" class="btn btn-sm btn-primary" disabled>
            Editar
        </button>
        <button id="btn-details" class="btn btn-sm btn-primary" disabled>
            Detalhes
        </button>
        <button id="btn-delete" class="btn btn-sm btn-danger" disabled>
            Desativar
        </button>
    </div>

    @{
        int total = Model.TotalCount;
        int pageSize = Model.PageSize;
        int page = Model.Page;

        int start = total == 0
            ? 0
            : ((page - 1) * pageSize) + 1;

        int end = Math.Min(page * pageSize, total);
    }
    <div class="d-flex justify-content-between align-items-center mt-3 gap-2">
        <small class="text-muted">
            @if (total > 0)
            {
                <span>Mostrando @start–@end de @total registros</span>
            }
            else
            {
                <span>Nenhum registro encontrado</span>
            }
        </small>
        <div class="d-flex align-items-center gap-3">
            <form method="get" class="m-0 p-0">

                <input type="hidden" name="search" value="@Model.Search" />

                <select name="pageSize"
                        class="form-select w-auto"
                        onchange="this.form.submit()">
                    @foreach (var size in new[] { 10, 25, 50, 100 })
                    {
                        <option value="@size" selected="@(size == Model.PageSize)">
                            @size por página
                        </option>
                    }
                </select>
            </form>

            @{
                var totalPages = (int)Math.Ceiling(
                    (double)Model.TotalCount / Model.PageSize
                );

                var search = Model.Search?.ToString();
            }
            <nav class="m-0 p-0">
                <ul class="pagination pagination-sm mb-0">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-pageSize="@pageSize"
                               asp-route-search="@search">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>

<script>
    let selectedId = null;

    document.addEventListener("DOMContentLoaded", function() {
        const table = document.getElementById("table");
        const rows = document.querySelectorAll("#table tbody tr");

        const btnEdit = document.getElementById("btn-edit");
        const btnDetails = document.getElementById("btn-details");
        const btnDelete = document.getElementById("btn-delete");

        function clearSelection() {
            rows.forEach(r => r.classList.remove("selected"));
            selectedId = null;

            btnEdit.disabled = true;
            btnDetails.disabled = true;
            btnDelete.disabled = true;
        }

        rows.forEach(function(row) {
            row.addEventListener("click", function(event) {
                event.stopPropagation();

                if (this.classList.contains("selected")) {
                    clearSelection();
                    return;
                }

                clearSelection();

                this.classList.add("selected");
                selectedId = this.dataset.id;

                btnEdit.disabled = false;
                btnDetails.disabled = false;
                btnDelete.disabled = false;
            });
        });

        document.addEventListener("click", function(event) {
            if (!table.contains(event.target)) {
                clearSelection();
            }
        });

        btnEdit.addEventListener("click", function() {
            if (selectedId) {
                window.location.href = `/Users/Edit/${selectedId}`;
            }
        });

        btnDetails.addEventListener("click", function() {
            if (selectedId) {
                window.location.href = `/Users/Details/${selectedId}`;
            }
        });

        btnDelete.addEventListener("click", function() {
            if (selectedId) {
                window.location.href = `/Users/Delete/${selectedId}`;
            }
        });
    });
</script>