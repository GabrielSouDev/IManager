@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Redefinir senha";
}
<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="text-center mb-4">
            <h4 class="fw-600">Redefinir senha</h4>
        </div>
        <form method="post" class="border p-4 shadow-sm rounded bg-white">
            @Html.AntiForgeryToken()
            <input asp-for="Email" type="hidden" />
            <input asp-for="Token" type="hidden" />
            <div class="mb-3">
                <label class="form-label fw-500 small">Nova senha: <span class="text-danger">*</span></label>
                <input asp-for="NewPassword" type="password" class="form-control" placeholder="Digite sua nova senha" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label class="form-label fw-500 small">Confirmar senha: <span class="text-danger">*</span></label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirme sua nova senha" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mt-3 small">
                    @Html.ValidationSummary()
                </div>
            }
            <button type="submit" class="btn btn-primary w-100">Redefinir senha</button>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}