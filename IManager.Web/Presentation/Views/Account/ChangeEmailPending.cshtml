@{
    ViewData["Title"] = "Verifique seu e-mail";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h2>Verifique seu e-mail</h2>
            <p class="text-muted">Enviamos um link de confirmação para o seu e-mail. Clique no link para alterar o seu email.</p>
            <form asp-action="Logout" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary">Ir para o login</button>
            </form>
        </div>
    </div>
</div>