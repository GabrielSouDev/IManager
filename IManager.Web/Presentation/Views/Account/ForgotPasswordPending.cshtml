@{
    ViewData["Title"] = "Verifique seu e-mail";
}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 text-center">
            <h2>Verifique seu e-mail</h2>
            <p class="text-muted">Enviamos um link para redefinir sua senha. Clique no link para continuar.</p>
            <a asp-action="Login" asp-controller="Account" class="btn btn-primary">Voltar ao login</a>
        </div>
    </div>
</div>