@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}
<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="text-center mb-4">
            <h4 class="fw-600">Bem-vindo</h4>
            <p class="text-muted small">Entre com sua conta para continuar</p>
        </div>
        <form asp-action="Login" method="post" class="border p-4 shadow-sm rounded bg-white">
            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-500 small">Email: <span class="text-danger">*</span></label>
                <input asp-for="Email" class="form-control" placeholder="Digite seu email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Password" class="form-label fw-500 small">Senha: <span class="text-danger">*</span></label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Digite sua senha" />
                <span asp-validation-for="Password" class="text-danger small"></span>
                <div class="text-end mt-1">
                    <a asp-controller="Account" asp-action="ForgotPassword" class="small text-muted">Esqueci minha senha</a>
                </div>
            </div>
            <button type="submit" class="btn btn-primary w-100">Entrar</button>
        </form>
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mt-3 small">
                @Html.ValidationSummary()
            </div>
        }
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}